# Server
NODE_ENV=development
PORT=5000

# Database (MongoDB Atlas)
# MONGODB_URI=mongodb+srv://theotrust_admin:Northwood%2322@cluster0.yufnhtm.mongodb.net/theotrust-charity?retryWrites=true&w=majority

# Local MongoDB (for testing without Atlas)
MONGODB_URI=mongodb://localhost:27017/theotrust-charity

# JWT - Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_generated_64_byte_secret_here
JWT_EXPIRE=24h

# Email (Optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=startupthings96@gmail.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=startupthings96@gmail.com

# Frontend URL
CLIENT_URL=http://localhost:5173

# Wonderful.org Integration
WONDERFUL_API_KEY=your-wonderful-api-key
WONDERFUL_SECRET_KEY=your-wonderful-secret-key
WONDERFUL_CHARITY_ID=your-charity-id

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
